generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. 零件与图纸字典 (Part & Drawings)
// ==========================================

/// 零件基础信息表 (作为数据字典使用，不包含库存概念)
model Part {
  /// 零件唯一主键 ID
  id           Int      @id @default(autoincrement())
  /// 零件名称
  name         String   @db.VarChar(100)
  /// 规格型号说明
  spec         String?  @db.VarChar(100)
  /// 常用价格配置列表，存储格式为 JSON (例: {"标准价": 10.0, "老客价": 9.5})
  commonPrices Json     @default("{}") @map("common_prices")
  /// 记录创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 记录最后更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  /// 关联：该零件下的所有工程图纸
  drawings   PartDrawing[]
  /// 关联：包含该零件的订单明细记录
  orderItems OrderItem[]

  @@map("part")
}

/// 零件工程图纸表
model PartDrawing {
  /// 图纸唯一主键 ID
  id         Int      @id @default(autoincrement())
  /// 关联的零件 ID
  partId     Int      @map("part_id")
  /// 原始文件名称 (例: 主轴承V2版_工程图.pdf)
  fileName   String   @map("file_name") @db.VarChar(255)
  /// 存储在 MinIO/OSS 中的对象键值路径
  fileKey    String   @map("file_key") @db.VarChar(255)
  /// 文件类型，用于前端判断渲染方式 (IMAGE 或 PDF)
  fileType   String   @map("file_type") @db.VarChar(20)
  /// 版本标识，是否为当前零件的最新图纸
  isLatest   Boolean  @default(true) @map("is_latest")
  /// 图纸上传时间
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  /// 关联：对应的零件主体
  part Part @relation(fields: [partId], references: [id])

  @@map("part_drawing")
}

// ==========================================
// 2. 核心业务流 (Order -> Delivery -> Billing)
// ==========================================

/// 内部销售订单/生产需求主表 (作为交易数据的源头与价格锚点)
model Order {
  /// 订单唯一主键 ID
  id           Int      @id @default(autoincrement())
  /// 客户或采购方公司名称
  customerName String   @map("customer_name") @db.VarChar(100)
  /// 订单履约状态 (PENDING待履约, PARTIAL_DELIVERED部分发货, DELIVERED全部发货, CLOSED_SHORT短交结案)
  status       String   @default("PENDING") @db.VarChar(50)
  /// 订单创建/开单时间
  createdAt    DateTime @default(now()) @map("created_at")

  /// 关联：订单包含的零件行项目
  items      OrderItem[]
  /// 关联：基于该订单生成的发货单集合
  deliveries DeliveryNote[]

  @@map("order")
}

/// 订单明细表 (包含核心的价格快照逻辑)
model OrderItem {
  /// 订单明细唯一主键 ID
  id           Int     @id @default(autoincrement())
  /// 关联的订单主表 ID
  orderId      Int     @map("order_id")
  /// 关联的零件字典 ID
  partId       Int     @map("part_id")
  /// 交易单价快照，开单时从常用价格中提取并硬拷贝至此，防篡改 (精度: 10位总长，2位小数)
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  /// 客户下单的原始需求数量
  orderedQty   Int     @map("ordered_qty")
  /// 已累计发货数量 (防超发校验的核心依据)
  deliveredQty Int     @default(0) @map("delivered_qty")

  /// 关联：所属订单主表
  order      Order          @relation(fields: [orderId], references: [id])
  /// 关联：对应的零件基准信息
  part       Part           @relation(fields: [partId], references: [id])
  /// 关联：由该明细生成的发货明细集合
  deliveries DeliveryItem[]

  @@map("order_item")
}

/// 发货单主表 (纯粹的物流执行凭证，不包含金额计算)
model DeliveryNote {
  /// 发货单唯一主键 ID
  id           Int      @id @default(autoincrement())
  /// 溯源关联的原始订单 ID
  orderId      Int      @map("order_id")
  /// 实际发货/出库日期
  deliveryDate DateTime @default(now()) @map("delivery_date")
  /// 发货单流转状态 (SHIPPED已发货, BILLED已核算对账)
  status       String   @default("SHIPPED") @db.VarChar(50)
  /// 整单维度的物流或异常备注 (例: 遇暴雨延迟发货)
  remark       String?  @db.VarChar(500)

  /// 关联：来源订单主表
  order Order          @relation(fields: [orderId], references: [id])
  /// 关联：发货单包含的零件明细项
  items DeliveryItem[]

  @@map("delivery_note")
}

/// 发货单明细表
model DeliveryItem {
  /// 发货明细唯一主键 ID
  id             Int     @id @default(autoincrement())
  /// 关联的发货单主表 ID
  deliveryNoteId Int     @map("delivery_note_id")
  /// 溯源关联的订单明细 ID (结算时通过此关联提取价格快照)
  orderItemId    Int     @map("order_item_id")
  /// 本次实际出库的发货数量
  shippedQty     Int     @map("shipped_qty")
  /// 行项目异常备注 (核心业务要求：记录报废、损耗等数量差异原因)
  remark         String? @db.VarChar(255)

  /// 关联：所属发货单主表
  deliveryNote DeliveryNote  @relation(fields: [deliveryNoteId], references: [id])
  /// 关联：溯源对应的订单明细记录
  orderItem    OrderItem     @relation(fields: [orderItemId], references: [id])
  /// 关联：基于该发货明细生成的费用结算条目
  billingItems BillingItem[]

  @@map("delivery_item")
}

/// 费用清单/对账单主表 (最终合并结算凭证)
model BillingStatement {
  /// 费用清单唯一主键 ID
  id           Int      @id @default(autoincrement())
  /// 结算对象客户名称
  customerName String   @map("customer_name") @db.VarChar(100)
  /// 该清单合并计算后的应收总金额
  totalAmount  Decimal  @map("total_amount") @db.Decimal(12, 2)
  /// 清单处理状态 (DRAFT待确认草稿, SEALED已电子签章防篡改, PAID已结清付款)
  status       String   @default("DRAFT") @db.VarChar(50)
  /// 清单生成日期
  createdAt    DateTime @default(now()) @map("created_at")

  /// 关联：该清单包含的所有费用计算明细行
  items BillingItem[]

  @@map("billing_statement")
}

/// 费用清单明细表
model BillingItem {
  /// 费用明细唯一主键 ID
  id             Int     @id @default(autoincrement())
  /// 关联的费用清单主表 ID
  billingId      Int     @map("billing_id")
  /// 溯源关联的发货明细 ID (若为系统基于发货单自动生成，则存在此关联)
  deliveryItemId Int?    @map("delivery_item_id")
  /// 费用项目文字描述 (系统生成时取零件名，手动添加时用于记录如“加急费”、“运费”等说明)
  description    String? @db.VarChar(255)
  /// 该明细行的核算最终金额 (系统公式：发货实发数 × 订单单价快照)
  amount         Decimal @db.Decimal(10, 2)

  /// 关联：所属费用清单主表
  billing      BillingStatement @relation(fields: [billingId], references: [id])
  /// 关联：溯源对应的发货明细记录
  deliveryItem DeliveryItem?    @relation(fields: [deliveryItemId], references: [id])

  @@map("billing_item")
}

// ==========================================
// 3. 印章与归档安全 (Seal & Documents)
// ==========================================

/// 公司电子印章库
model Seal {
  /// 印章唯一主键 ID
  id       Int     @id @default(autoincrement())
  /// 印章显示名称 (例: 财务专用章)
  name     String  @db.VarChar(50)
  /// 存储在 MinIO 中的透明底 PNG 印章图片路径
  fileKey  String  @map("file_key") @db.VarChar(255)
  /// 启用状态标识 (停用后不可用于新文档合成)
  isActive Boolean @default(true) @map("is_active")

  /// 关联：该印章的全部盖章调用审计日志
  logs SealUsageLog[]

  @@map("seal")
}

/// 电子签章调用审计日志表 (关键安全与防抵赖机制)
model SealUsageLog {
  /// 日志唯一主键 ID
  id         Int      @id @default(autoincrement())
  /// 被使用的印章 ID
  sealId     Int      @map("seal_id")
  /// 执行盖章操作的系统账号 ID
  userId     Int      @map("user_id")
  /// 目标归档文档的业务类型 (BILLING_STATEMENT, CONTRACT 等)
  targetType String   @map("target_type") @db.VarChar(50)
  /// 目标归档文档对应的业务主键 ID
  targetId   Int      @map("target_id")
  /// 执行盖章合成的精确服务器时间
  actionTime DateTime @default(now()) @map("action_time")
  /// 操作发起方 IP 地址
  ipAddress  String?  @map("ip_address") @db.VarChar(50)

  /// 关联：使用的印章主体
  seal Seal @relation(fields: [sealId], references: [id])

  @@map("seal_usage_log")
}

/// 统一 PDF 电子文档与防篡改归档表
model Document {
  /// 文档归档唯一主键 ID
  id          Int      @id @default(autoincrement())
  /// 关联的业务单据类型 (ORDER, DELIVERY, BILLING 等)
  targetType  String   @map("target_type") @db.VarChar(50)
  /// 关联的业务单据 ID
  targetId    Int      @map("target_id")
  /// 最终展示文件名称
  fileName    String   @map("file_name") @db.VarChar(255)
  /// 原始未盖章的纯净 PDF 在 MinIO 中的路径键值
  originalKey String   @map("original_key") @db.VarChar(255)
  /// 经服务端 pdf-lib 合成印章并展平后的防篡改 PDF 路径键值
  signedKey   String?  @map("signed_key") @db.VarChar(255)
  /// 合成文件的 SHA-256 哈希值摘要，用于后续法律效力验证
  fileHash    String?  @map("file_hash") @db.Char(64)
  /// 文档当前状态 (DRAFT未盖章, SIGNED已盖章防篡改)
  status      String   @default("DRAFT") @db.VarChar(50)
  /// 文档生成时间
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("document")
}
