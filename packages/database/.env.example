# PostgreSQL connection used by Prisma and local startup scripts
DATABASE_URL="postgresql://postgres:your-password@127.0.0.1:5433/mto_erp?schema=public"

# One-time fallback only for legacy local databases created via `prisma db push`
PRISMA_DEV_ALLOW_DB_PUSH_FALLBACK=false

# Auth bootstrap for local development
JWT_SECRET="replace-this-in-your-local-env"
AUTH_INIT_USERNAME=admin
AUTH_INIT_PASSWORD=admin123456
AUTH_INIT_REAL_NAME=系统管理员

# MinIO / S3-compatible object storage
# macOS local MinIO example:
# MINIO_ENDPOINT=127.0.0.1
# MINIO_PORT=9000
# MINIO_USE_SSL=false
#
# Windows + NAS MinIO example:
# MINIO_ENDPOINT=your-nas-host-or-ip
# MINIO_PORT=9000
# MINIO_USE_SSL=false
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mto-erp
